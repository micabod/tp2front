---
import { supabase } from "../lib/supabase"
---

<html lang="es">

<head>
  <meta charset="UTF-8" />
  <title>Dashboard</title>
</head>

<body>

  <h1>Mis tareas</h1>

  <button onclick="logout()">
    Cerrar sesión
  </button>

  <hr>

  <input
    id="titulo"
    placeholder="Título tarea"
  />

  <br><br>

  <input
    id="prioridad"
    type="number"
    placeholder="Prioridad 1-3"
  />

  <br><br>

  <input
    id="tiempo"
    type="number"
    placeholder="Tiempo en minutos"
  />

  <br><br>

  <button onclick="crear()">
    Crear tarea
  </button>

  <button onclick="recomendar()">
    ¿Qué hago ahora?
  </button>

  <h2 id="recomendacion"></h2>

  <hr>

  <ul id="lista"></ul>

  <script type="module">

    import { supabase }
    from "../lib/supabase"

    async function getUser() {

      const { data } =
        await supabase.auth.getUser()

      return data.user
    }

    async function cargar() {

      const { data } =
        await supabase
          .from("tareas")
          .select("*")

      const lista =
        document.getElementById("lista")

      lista.innerHTML = ""

      data.forEach(tarea => {

        const li =
          document.createElement("li")

        li.innerHTML = `
          ${tarea.titulo}
          | prioridad: ${tarea.prioridad}
          | estado: ${tarea.estado}

          <button onclick="completar('${tarea.id}')">
            Completar
          </button>
        `

        lista.appendChild(li)
      })
    }

    async function crear() {

      const user =
        await getUser()

      const titulo =
        document.getElementById("titulo").value

      const prioridad =
        parseInt(
          document.getElementById("prioridad").value
        )

      const tiempo =
        parseInt(
          document.getElementById("tiempo").value
        )

      await supabase
        .from("tareas")
        .insert([
          {
            titulo,
            prioridad,
            tiempo,
            estado: "pendiente",
            user_id: user.id
          }
        ])

      cargar()
    }

    async function completar(id) {

      await supabase
        .from("tareas")
        .update({
          estado: "hecha"
        })
        .eq("id", id)

      cargar()
    }

    function elegirTarea(tareas) {

      let pendientes =
        tareas.filter(
          tarea =>
            tarea.estado === "pendiente"
        )

      pendientes.sort(
        (a, b) =>
          b.prioridad - a.prioridad
      )

      return pendientes[0]
    }

    async function recomendar() {

      const { data } =
        await supabase
          .from("tareas")
          .select("*")

      const tarea =
        elegirTarea(data)

      const texto =
        document.getElementById(
          "recomendacion"
        )

      if (tarea) {

        texto.innerText =
          "Hacé esta tarea: " +
          tarea.titulo
      }

      else {

        texto.innerText =
          "No hay tareas pendientes"
      }
    }

    async function logout() {

      await supabase.auth.signOut()

      window.location.href = "/"
    }

    window.crear = crear
    window.completar = completar
    window.recomendar = recomendar
    window.logout = logout

    cargar()

  </script>

</body>

</html>