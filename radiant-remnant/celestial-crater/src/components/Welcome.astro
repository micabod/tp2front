---
---

<div id="container">
	<div class="background-decoration">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<main>
		<section id="hero">
			<div class="hero-content">
				<div class="badge">Welcome to Astro</div>
				
				<h1>
					Construye sitios<br>
					<span class="gradient-text">rápidos y modernos</span>
				</h1>

				<section id="links">
					<a class="button button-primary" href="https://docs.astro.build">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
						</svg>
						Documentación
					</a>
					<a class="button button-secondary" href="https://astro.build/chat">
						<svg width="20" height="20" viewBox="0 0 127.14 96.36" fill="currentColor">
							<path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"></path>
						</svg>
						Discord
					</a>
				</section>
			</div>
		</section>
	</main>

	<a href="https://astro.build/blog/astro-6-beta/" id="news-card" class="news-box">
		<div class="news-icon">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
				<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
				<polyline points="13 2 13 9 20 9"></polyline>
				<line x1="9" y1="15" x2="15" y2="15"></line>
				<line x1="9" y1="19" x2="15" y2="19"></line>
			</svg>
		</div>
		<div class="news-content">
			<h3>Astro 6.0 Beta</h3>
			<p>Servidor de desarrollo rediseñado, fuentes mejoradas, colecciones en vivo y más características increíbles.</p>
		</div>
		<div class="news-arrow">→</div>
	</a>
</div>

<style>
	#container {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		height: 100%;
		position: relative;
		overflow: hidden;
	}
	.background-decoration {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.6;
	}

	.blob-1 {
		width: 300px;
		height: 300px;
		background: linear-gradient(135deg, #3245ff 0%, #bc52ee 100%);
		top: -100px;
		left: -100px;
		animation: float 8s ease-in-out infinite;
	}

	.blob-2 {
		width: 250px;
		height: 250px;
		background: linear-gradient(135deg, #f041ff 0%, #bc52ee 100%);
		bottom: -50px;
		right: -50px;
		animation: float 10s ease-in-out infinite 2s;
	}

	.blob-3 {
		width: 200px;
		height: 200px;
		background: linear-gradient(135deg, #3245ff 0%, #f041ff 100%);
		top: 50%;
		right: 10%;
		animation: float 12s ease-in-out infinite 4s;
	}

	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-30px);
		}
	}

	main {
		height: 100%;
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 2rem;
	}

	#hero {
		width: 100%;
		max-width: 700px;
		animation: fadeIn 0.8s ease-out;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		background: rgba(50, 69, 255, 0.1);
		border: 1px solid rgba(50, 69, 255, 0.3);
		border-radius: 50px;
		font-size: 0.875rem;
		font-weight: 500;
		color: #3245ff;
		width: fit-content;
		animation: slideInLeft 0.8s ease-out;
	}

	h1 {
		font-size: 3rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-dark);
		margin: 0;
		animation: slideInLeft 0.8s ease-out 0.1s both;
	}

	.gradient-text {
		background: linear-gradient(135deg, #3245ff 0%, #bc52ee 50%, #f041ff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		display: inline-block;
	}

	.subtitle {
		font-size: 1.125rem;
		color: var(--color-gray);
		line-height: 1.6;
		margin: 0;
		animation: slideInLeft 0.8s ease-out 0.2s both;
	}

	#links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		animation: slideInLeft 0.8s ease-out 0.3s both;
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.875rem 1.75rem;
		text-decoration: none;
		border-radius: 12px;
		font-weight: 600;
		font-size: 1rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border: none;
		cursor: pointer;
		white-space: nowrap;
	}

	.button-primary {
		background: var(--gradient-primary);
		color: white;
		box-shadow: 0 10px 30px -5px rgba(50, 69, 255, 0.3);
	}

	.button-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 15px 40px -5px rgba(50, 69, 255, 0.4);
	}

	.button-primary:active {
		transform: translateY(0px);
	}

	.button-secondary {
		background: rgba(255, 255, 255, 0.8);
		color: var(--color-primary);
		border: 2px solid var(--color-border);
		backdrop-filter: blur(10px);
	}

	.button-secondary:hover {
		background: rgba(255, 255, 255, 0.95);
		transform: translateY(-2px);
		border-color: var(--color-primary);
	}

	.button svg {
		width: 20px;
		height: 20px;
	}

	/* News Card */
	#news-card {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		max-width: 350px;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(20px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 16px;
		text-decoration: none;
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		transition: all 0.3s ease;
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.1);
		animation: fadeIn 1s ease-out 0.6s both;
	}

	#news-card:hover {
		background: rgba(255, 255, 255, 0.95);
		transform: translateY(-4px);
		box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.15);
	}

	.news-icon {
		flex-shrink: 0;
		width: 48px;
		height: 48px;
		background: var(--gradient-primary);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
	}

	.news-content {
		flex: 1;
	}

	.news-content h3 {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-dark);
		margin: 0 0 0.5rem;
	}

	.news-content p {
		font-size: 0.875rem;
		color: var(--color-gray);
		margin: 0;
		line-height: 1.5;
	}

	.news-arrow {
		font-size: 1.25rem;
		color: var(--color-primary);
		flex-shrink: 0;
		transition: transform 0.3s ease;
	}

	#news-card:hover .news-arrow {
		transform: translateX(4px);
	}

	/* Responsive */
	@media (max-width: 768px) {
		h1 {
			font-size: 2rem;
		}

		.subtitle {
			font-size: 1rem;
		}

		#links {
			flex-direction: column;
			gap: 0.75rem;
		}

		.button {
			width: 100%;
			justify-content: center;
		}

		#news-card {
			bottom: 1rem;
			right: 1rem;
			left: 1rem;
			max-width: none;
		}

		.blob-1,
		.blob-2,
		.blob-3 {
			opacity: 0.3;
		}
	}

	@media (max-height: 700px) {
		#news-card {
			display: none;
		}
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
</style>