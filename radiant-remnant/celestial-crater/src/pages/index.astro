---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<section id="hero">
			<h1>Welcome to Astro</h1>
			<section id="links">
			</section>
		</section>
	</main>
</Layout>

<style>
	main {
		display: flex;
		justify-content: center;
		align-items: center;
		height: 100%;
	}

	#hero {
		text-align: center;
		padding: 2rem;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0 0 1rem;
	}

	p {
		font-size: 1.1rem;
		margin-bottom: 2rem;
	}

	code {
		background: #f0f0f0;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
	}

	#links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	#links a {
		padding: 0.75rem 1.5rem;
		text-decoration: none;
		border-radius: 8px;
		transition: all 0.2s;
		color: #111827;
	}

	#links a.button {
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		color: white;
	}

	#links a.button:hover {
		transform: scale(1.05);
	}

	#links a:hover {
		opacity: 0.8;
	}
</style>